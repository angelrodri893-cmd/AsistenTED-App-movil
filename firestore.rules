rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /progress/{tramiteId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /historial/{historialId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /recordatorios/{reminderId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /tramites/{tramiteId}/comentarios/{commentId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.tramiteId == tramiteId
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000;
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }
  }
}

